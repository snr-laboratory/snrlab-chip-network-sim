// mcp program to verify sending multiple data pkts at same time


$display("RUNNING VER_PASS_DATA.MCP");
$display("run length = 300 us");
$display("This tests an edge case where packets hit each of 4 POSI simultaneously");
$display("Expect 4 output packets (want to make sure LArPix doesn't choke");
$display("Set torture=1 in larpix_single_tb, otherwise you will get 1 packet");
$display("Begin Simulation.");

#10000
  $display("Enable Downstream PISO0 (for returning data to FPGA)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ENABLE_PISO_DOWN,8'h01);


#100000
 $display("Send Data packets to all POSI ports");
 sendDataToLarpix(10'h00F,8'hFF,6'h08,28'h0);








