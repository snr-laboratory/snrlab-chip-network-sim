// mcp program to test basic GLOBAL_ID  
$display("RUNNING VER_global.MCP");
$display("run length = 200 us");    
$display("If test fails, confirm task sendWordToLarpix is configured for correct parity and correct magic number");
$display("sendWordToLarpix defined in larpix_v3/testbench/larpix_tasks");
$display("If test fails, verify sendWordToLarpix task\n");

#10000
  $display("Enable upstream PISO1 (for sending global data on)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ENABLE_PISO_UP,8'h02);

#10000
  $display("Enable Downstream PISO0 (for returning data to FPGA)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ENABLE_PISO_DOWN,8'h01);

#10000
$display("write 10d to GLOBAL_THRESH"); 
sendWordToLarpix(CONFIG_WRITE_OP,8'hFF,GLOBAL_THRESH,8'h0a);

#200

$display("also check for a packet on PISO1 (this is a config_write_OP)");
#10000
  $display("Read Back test: 10d/0x0A expected");
  sendWordToLarpix(CONFIG_READ_OP,8'h01,GLOBAL_THRESH,8'h01);





