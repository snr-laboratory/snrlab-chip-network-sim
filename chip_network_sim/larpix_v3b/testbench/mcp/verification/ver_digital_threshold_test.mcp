// mcp program to test digital threshold programming
$display("RUNNING VER_DIGITAL_THRESHOLD_TEST.MCP");
$display("run length = 80 us");    
$display("If test fails, confirm task sendWordToLarpix is configured for correct parity and correct magic number");
$display("sendWordToLarpix defined in larpix_v3/testbench/larpix_tasks/n");

#20000
$display("write 10d to GLOBAL_THRESH"); 
sendWordToLarpix(CONFIG_WRITE_OP,8'h01,GLOBAL_THRESH,8'h0a);

#10000
$display("Set [9:7] MSBs of Digital Threshold to 3'b100"); 
sendWordToLarpix(CONFIG_WRITE_OP,8'h01,DIGITAL_THRESHOLD_MSB,8'h80);

#10000
$display("Set [6:5] MSBs of Digital Threshold to 2'b00"); 
sendWordToLarpix(CONFIG_WRITE_OP,8'h01,DIGITAL_THRESHOLD_MSB+1,8'h00);


#10000
$display("Set LSBs of channel 4 Digital Threshold to 5'b01010"); 
sendWordToLarpix(CONFIG_WRITE_OP,8'h01,DIGITAL_THRESHOLD_LSB+4,8'h0A);

#10000
  $display("Enable Downstream PISO0 (for returning data to FPGA)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ENABLE_PISO_DOWN,8'h01);

#20000
  $display("enable channels 0 - 7 (enable CSA)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,CSA_ENABLE,8'hFF);

#30000
  $display("enable channels 0-7 (turn off channel mask)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,CHANNEL_MASK,0);

#10000
  $display("Verify that channel four threshold is: 10'b10_0000_1010");

#10000
  $display("Read Back test: 10d/0x0A expected");
  sendWordToLarpix(CONFIG_READ_OP,8'h01,DIGITAL_THRESHOLD_LSB+4,8'h0F);

#200000
    charge_in_r[4] = -3.0e-15;
    $display("charge deposition in channel 4");
#20
    charge_in_r[4] = 0.0;  

#500000
    charge_in_r[4] = -6.8e-15;
    $display("charge deposition in channel 4");
#20
    charge_in_r[4] = 0.0;  

