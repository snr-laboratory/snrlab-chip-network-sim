// mcp program to verify statistics interface 


$display("RUNNING VER_STATS.MCP");
$display("run length = 150 us");
$display("Set burst mode = 4");
$display("Expect 4 config ops, 1 data op, FIFO high water = 1");
$display("First packet marker only set for first packet");
$display("Begin Simulation.");

#10000
$display("write 10d to GLOBAL_THRESH"); 
sendWordToLarpix(CONFIG_WRITE_OP,8'h01,GLOBAL_THRESH,8'h0a);

#10000
  $display("Enable Downstream PISO0 (for returning data to FPGA)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ENABLE_PISO_DOWN,8'h01);

#10000
  $display("enable channels 0 - 7 (enable CSA)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,CSA_ENABLE,8'hFF);

#10000
  $display("enable channels 0-7 (turn off channel mask)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,CHANNEL_MASK,0);

// simulate charge input
//
#20000

for (int i = 0; i < 1; i++) begin
    charge_in_r[i] = -2.8e-15;
    $display("charge deposition in channel %d", i);
#20
    charge_in_r[i] = 0.0;  
end  

#10000
  $display("Read Out Statistics: config writes (expect 4)");
  sendWordToLarpix_stats(CONFIG_READ_OP,8'h01,ENABLE_PISO_DOWN,8'h01,STATS_LOCAL_CONFIG_WRITES);

#10000
  $display("Read Out Statistics: local data pkts (expect 1)");
  sendWordToLarpix_stats(CONFIG_READ_OP,8'h01,ENABLE_PISO_DOWN,8'h01,STATS_LOCAL_DATA_PACKETS);




