// mcp program to verify burst mode


$display("RUNNING VER_PER_TRIG.MCP");
$display("run length = 150 us");
$display("Expect two packets");
$display("First, we do a periodic trigger, then a natural hit.");
$display("Right after we do a periodic trigger. We want to make sure that the");
$display("Periodic trigger is veto'ed in this situation.");
$display("Begin Simulation.");

#10000
$display("write 10d to GLOBAL_THRESH"); 
sendWordToLarpix(CONFIG_WRITE_OP,8'h01,GLOBAL_THRESH,8'h0a);

#10000
  $display("Enable Downstream PISO0 (for returning data to FPGA)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ENABLE_PISO_DOWN,8'h01);

#10000
  $display("enable channels 0 - 7 (enable CSA)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,CSA_ENABLE,8'hFF);

#10000
  $display("enable channels 0-7 (turn off channel mask)");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,CHANNEL_MASK,0);

//#10000
//  $display("set ADC_HOLD_DELAY=1");
//  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ADC_HOLD_DELAY,8'h01);


#10000
  $display("turn off periodic trigger mask for channels 0 - 7");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,PER_TRIG_MASK,0);


#10000
  $display("set periodic trigger cycles to 1024");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,PER_TRIG_CYC,8'hd64);


#10000
  $display("enable periodic trigger");
  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ENABLE_TRIG_MODES,8'h68);



//#10000 
//  $display("set ADC Burst mode to 4");
//  sendWordToLarpix(CONFIG_WRITE_OP,8'h01,ADC_BURST,8'h04);

// simulate charge input
//
#195500


for (int i = 0; i < 1; i++) begin
    charge_in_r[i] = -2.8e-15;
    $display("charge deposition in channel %d", i);
#20
    charge_in_r[i] = 0.0;  
end  




